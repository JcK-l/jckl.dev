---
import Layout from "../layouts/MainLayout.astro";
import Contact from "../components/Sections/Contact";
import Hero from "../components/Sections/Hero";
import About from "../components/Sections/About";
import Projects from "../components/Sections/Projects";
import TransitionSection from "../components/Sections/TransitionSection";
import PhoneResults from "../components/Sections/PhoneResults";
import StarConstellation from "../components/Sections/StarConstellation";
import CrtMission from "../components/Sections/CrtMission";
import { ThemeDebugToggle } from "../components/ThemeDebugToggle";

const showThemeDebugToggle = import.meta.env.DEV;
---

<Layout title="Welcome to my site!">
  {showThemeDebugToggle ? <ThemeDebugToggle client:load /> : null}
  <main>
    <section class="bg-fgColor" id="hero">
      <Hero client:load />
    </section>

    <section class="" id="starConstellation">
      <StarConstellation client:load />
    </section>

    <section class="bg-fgColor" id="about">
      <About client:only="react" />
    </section>

    <section class="" id="crtMission">
      <CrtMission client:load />
    </section>

    <section class="bg-fgColor" id="projects">
      <Projects client:load />
    </section>

    <section class="" id="phoneTransition">
      <TransitionSection client:load />
    </section>

    <section class="bg-fgColor" id="phone">
      <PhoneResults client:load />
    </section>

    <section class="" id="contact">
      <Contact client:idle />
    </section>
  </main>
</Layout>

<!-- The stars align, to ifinity and beyond! Say hello   -->
