---
import Layout from "../layouts/MainLayout.astro";
import Contact from "../components/Sections/Contact";
import Hero from "../components/Sections/Hero";
import About from "../components/Sections/About";
import Projects from "../components/Sections/Projects";
import Connection from "../components/Sections/Connection";
import Call from "../components/Sections/Call";
import StarConstellation from "../components/Sections/StarConstellation";
import CrtMission from "../components/Sections/CrtMission";
import { ReactScanDebug } from "../components/ReactScanDebug";
import { DebugStatePanel } from "../components/DebugStatePanel";
import { E2EStateBootstrap } from "../components/E2EStateBootstrap";

const showDebugStatePanel = import.meta.env.DEV;
const showReactScanDebug = import.meta.env.DEV;
const showE2EStateBootstrap = import.meta.env.DEV;
---

<Layout title="Welcome to my site!">
  {showE2EStateBootstrap ? <E2EStateBootstrap client:load /> : null}
  {showDebugStatePanel ? <DebugStatePanel client:load /> : null}
  {showReactScanDebug ? <ReactScanDebug client:load /> : null}
  <main>
    <section class="bg-fgColor" id="hero">
      <Hero client:load />
    </section>

    <section id="starConstellation">
      <StarConstellation client:load />
    </section>

    <section 
      class="bg-fgColor" 
      id="about"
    >
      <About client:load />
    </section>

    <section id="crtMission">
      <CrtMission client:load />
    </section>

    <section class="bg-fgColor" id="projects">
      <Projects client:load />
    </section>

    <section id="connection">
      <Connection client:load />
    </section>

    <section class="bg-fgColor" id="call">
      <Call client:load />
    </section>

    <section id="contact">
      <Contact client:load />
    </section>
  </main>
</Layout>

<!-- The stars align, to ifinity and beyond! Say hello   -->
