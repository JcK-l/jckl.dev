---
import Layout from "../layouts/MainLayout.astro";
import Contact from "../components/Sections/Contact";
import Hero from "../components/Sections/Hero";
import About from "../components/Sections/About";
import Projects from "../components/Sections/Projects";
import Connection from "../components/Sections/Connection";
import Call from "../components/Sections/Call";
import StarConstellation from "../components/Sections/StarConstellation";
import CrtMission from "../components/Sections/CrtMission";
import { ThemeDebugToggle } from "../components/ThemeDebugToggle";

const showThemeDebugToggle = import.meta.env.DEV;
---

<Layout title="Welcome to my site!">
  {showThemeDebugToggle ? <ThemeDebugToggle client:load /> : null}
  <main>
    <section class="bg-fgColor" id="hero">
      <Hero client:idle />
    </section>

    <section
      class="deferred-section"
      id="starConstellation"
      style="--deferred-section-size: 780px;"
    >
      <StarConstellation client:visible />
    </section>

    <section 
      class="bg-fgColor" 
      id="about"
      style="--deferred-section-size: 1200px;"
    >
      <About client:visible />
    </section>

    <section
      class="deferred-section"
      id="crtMission"
      style="--deferred-section-size: 1100px;"
    >
      <CrtMission client:visible />
    </section>

    <section
      class="bg-fgColor deferred-section"
      id="projects"
      style="--deferred-section-size: 760px;"
    >
      <Projects client:visible />
    </section>

    <section
      class="deferred-section"
      id="connection"
      style="--deferred-section-size: 880px;"
    >
      <Connection client:visible />
    </section>

    <section
      class="bg-fgColor deferred-section"
      id="call"
      style="--deferred-section-size: 980px;"
    >
      <Call client:visible />
    </section>

    <section
      class="deferred-section"
      id="contact"
      style="--deferred-section-size: 840px;"
    >
      <Contact client:visible />
    </section>
  </main>
</Layout>

<!-- The stars align, to ifinity and beyond! Say hello   -->
